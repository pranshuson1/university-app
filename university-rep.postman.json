{
  "info": {
    "name": "University ERP API",
    "_postman_id": "12345678-abcd-efgh-ijkl-1234567890ab",
    "description": "Postman collection for University ERP Node.js API with Auth & RBAC",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student1@example.com\",\n  \"password\": \"123456\",\n  \"role\": \"student\",\n  \"studentId\": 1\n}"
            }
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student1@example.com\",\n  \"password\": \"123456\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Students",
      "item": [
        {
          "name": "Create Student (Faculty only)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/students",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"dob\": \"2000-05-10\"\n}"
            }
          }
        },
        {
          "name": "Get All Students (Faculty only)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/students"
          }
        },
        {
          "name": "Get Student by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/students/1"
          }
        },
        {
          "name": "Enroll in Course (Student only)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/students/1/enroll",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"courseId\": 1\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Courses",
      "item": [
        {
          "name": "Create Course (Faculty only)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/courses",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Computer Science 101\"\n}"
            }
          }
        },
        {
          "name": "Get All Courses",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/courses"
          }
        },
        {
          "name": "Get Course by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/courses/1"
          }
        }
      ]
    },
    {
      "name": "Exams",
      "item": [
        {
          "name": "Create Exam (Faculty only)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/exams",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"courseId\": 1,\n  \"name\": \"Midterm Exam\",\n  \"date\": \"2025-10-15\"\n}"
            }
          }
        },
        {
          "name": "Get All Exams",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/exams"
          }
        },
        {
          "name": "Add Result (Faculty only)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/exams/1/result",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"studentId\": 1,\n  \"marks\": 85,\n  \"status\": \"pass\"\n}"
            }
          }
        },
        {
          "name": "Get Student Results",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/exams/student/1"
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Pay Fees (Student only)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/payments/pay",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"studentId\": 1,\n  \"amount\": 5000\n}"
            }
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "token", "value": "" }
  ]
}
